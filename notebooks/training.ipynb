# 🤖 CS Algorithm Q&A Assistant — Training Notebook

Fine-tunes Google Gemma 2B on a custom DSA dataset using QLoRA.

## ⚠️ Before Running
- Set Accelerator to **GPU T4 x2** in Kaggle settings
- Turn **Internet ON**
- Add your **HF_TOKEN** to Kaggle Secrets
- Add the processed dataset as a Kaggle input dataset

## 📊 Expected Results
- Training time: ~2-3 hours on Kaggle T4
- Final loss: ~0.22
- Model size: ~113MB (LoRA adapter only)
# Cell 0 — Force single GPU (must run before any imports)
import os
os.environ['CUDA_VISIBLE_DEVICES'] = '0'
print('✅ Single GPU mode')
# Cell 1 — Install packages
!pip install -q -U bitsandbytes
!pip install -q -U transformers
!pip install -q -U peft
!pip install -q -U trl
!pip install -q -U accelerate
!pip install -q datasets gdown
print('✅ Packages installed!')
# Cell 2 — Download tokenized dataset from Google Drive
import os
os.makedirs('data/processed', exist_ok=True)
os.makedirs('models/checkpoints', exist_ok=True)
os.makedirs('models/final', exist_ok=True)

print('Downloading dataset...')
!gdown --folder 'https://drive.google.com/drive/folders/1rf-W5VvA6if5Y0b_X5DdIliZjG6EnfLz?usp=sharing' -O data/processed --remaining-ok
print('✅ Dataset downloaded!')
# Cell 3 — Login to HuggingFace
from kaggle_secrets import UserSecretsClient
from huggingface_hub import login

secrets = UserSecretsClient()
HF_TOKEN = secrets.get_secret('HF_TOKEN')
login(token=HF_TOKEN)
print('✅ Logged in to HuggingFace!')
# Cell 4 — Imports
import torch
from transformers import AutoTokenizer, AutoModelForCausalLM, BitsAndBytesConfig
from peft import LoraConfig, get_peft_model, prepare_model_for_kbit_training, TaskType
from datasets import load_from_disk
from trl import SFTTrainer, SFTConfig
import time

print(f'PyTorch: {torch.__version__}')
print(f'CUDA available: {torch.cuda.is_available()}')
if torch.cuda.is_available():
    print(f'GPU: {torch.cuda.get_device_name(0)}')
    print(f'VRAM: {torch.cuda.get_device_properties(0).total_memory/1e9:.1f} GB')
# Cell 5 — Load tokenized dataset
dataset = load_from_disk('data/processed/tokenized_dataset')
train_tokenized = dataset['train']
val_tokenized = dataset['validation']
print(f'✅ Train: {len(train_tokenized):,} | Val: {len(val_tokenized):,}')
print(f'Sample keys: {train_tokenized[0].keys()}')
# Cell 6 — Load Gemma 2B in 4-bit quantization
MODEL_NAME = 'google/gemma-2b'

bnb_config = BitsAndBytesConfig(
    load_in_4bit=True,
    bnb_4bit_quant_type='nf4',
    bnb_4bit_compute_dtype=torch.float16,
    bnb_4bit_use_double_quant=True
)

print('Loading Gemma 2B...')
model = AutoModelForCausalLM.from_pretrained(
    MODEL_NAME,
    quantization_config=bnb_config,
    device_map={'': 0},  # Force single GPU
    token=HF_TOKEN
)
model.config.use_cache = False

tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME, token=HF_TOKEN)
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token

print(f'✅ Model loaded on: {next(model.parameters()).device}')
print(f'VRAM used: {torch.cuda.memory_allocated(0)/1e9:.2f} GB')
# Cell 7 — Attach LoRA adapter (QLoRA setup)
model = prepare_model_for_kbit_training(model)

lora_config = LoraConfig(
    r=16,
    lora_alpha=32,
    lora_dropout=0.05,
    bias='none',
    task_type=TaskType.CAUSAL_LM,
    target_modules=['q_proj', 'k_proj', 'v_proj', 'o_proj',
                    'gate_proj', 'up_proj', 'down_proj']
)

model = get_peft_model(model, lora_config)
model.print_trainable_parameters()
print('✅ LoRA attached!')
# Cell 8 — Setup SFT Trainer
training_args = SFTConfig(
    output_dir='models/checkpoints',
    num_train_epochs=3,
    per_device_train_batch_size=2,
    per_device_eval_batch_size=2,
    gradient_accumulation_steps=4,
    gradient_checkpointing=True,
    fp16=False,
    bf16=False,
    learning_rate=2e-4,
    weight_decay=0.001,
    lr_scheduler_type='cosine',
    warmup_steps=50,
    max_grad_norm=0.3,
    logging_steps=10,
    save_steps=25,
    eval_strategy='steps',
    eval_steps=25,
    save_strategy='steps',
    load_best_model_at_end=True,
    save_total_limit=3,
    report_to='none',
    seed=42,
)

trainer = SFTTrainer(
    model=model,
    args=training_args,
    train_dataset=train_tokenized,
    eval_dataset=val_tokenized,
    processing_class=tokenizer,
)
print('✅ Trainer ready!')
# Cell 9 — Train!
print('Starting training...')
start = time.time()
result = trainer.train()
elapsed = time.time() - start
print(f'✅ Done! {elapsed/60:.1f} min | Loss: {result.training_loss:.4f}')
# Cell 10 — Save final model
import os
os.makedirs('models/final', exist_ok=True)
model.save_pretrained('models/final')
tokenizer.save_pretrained('models/final')

# Check size
total = 0
for f in os.listdir('models/final'):
    size = os.path.getsize(f'models/final/{f}')
    total += size
    print(f'{f}: {size/1e6:.1f} MB')
print(f'\nTotal: {total/1e6:.1f} MB')
print('✅ Model saved!')
# Cell 11 — Upload to HuggingFace Hub
from huggingface_hub import HfApi, create_repo

api = HfApi()
username = api.whoami(token=HF_TOKEN)['name']
repo_id = f'{username}/cs-algo-assistant'

create_repo(repo_id, token=HF_TOKEN, exist_ok=True)
api.upload_folder(
    folder_path='models/final',
    repo_id=repo_id,
    token=HF_TOKEN
)
print(f'✅ Model uploaded to: https://huggingface.co/{repo_id}')
