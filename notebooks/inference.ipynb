   "outputs": [],
   "source": [
    "# Cell 4 — Login to HuggingFace\n",
    "from google.colab import userdata\n",
    "from huggingface_hub import login\n",
    "\n",
    "# Option 1: From Colab secrets\n",
    "try:\n",
    "    HF_TOKEN = userdata.get('HF_TOKEN')\n",
    "except:\n",
    "    HF_TOKEN = input('Enter your HuggingFace token: ')\n",
    "\n",
    "login(token=HF_TOKEN)\n",
    "print('✅ Logged in!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 5 — Load model\n",
    "import torch\n",
    "from transformers import AutoTokenizer, AutoModelForCausalLM, BitsAndBytesConfig\n",
    "from peft import PeftModel\n",
    "\n",
    "MODEL_NAME = 'google/gemma-2b'\n",
    "ADAPTER_PATH = '/content/model'\n",
    "\n",
    "# Load tokenizer\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
    "\n",
    "# 4-bit quantization config\n",
    "bnb_config = BitsAndBytesConfig(\n",
    "    load_in_4bit=True,\n",
    "    bnb_4bit_quant_type='nf4',\n",
    "    bnb_4bit_compute_dtype=torch.float16,\n",
    "    bnb_4bit_use_double_quant=True\n",
    ")\n",
    "\n",
    "print('Loading base model...')\n",
    "base_model = AutoModelForCausalLM.from_pretrained(\n",
    "    MODEL_NAME,\n",
    "    quantization_config=bnb_config,\n",
    "    device_map='auto'\n",
    ")\n",
    "\n",
    "print('Loading LoRA adapter...')\n",
    "model = PeftModel.from_pretrained(base_model, ADAPTER_PATH)\n",
    "model.eval()\n",
    "print('✅ Model ready!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 6 — Inference function\n",
    "def ask(question, max_new_tokens=200):\n",
    "    if not question.strip():\n",
    "        return 'Please ask a question!'\n",
    "\n",
    "    prompt = f'<start_of_turn>user\\n{question}<end_of_turn>\\n<start_of_turn>model\\n'\n",
    "    inputs = tokenizer(prompt, return_tensors='pt').to('cuda')\n",
    "\n",
    "    with torch.no_grad():\n",
    "        outputs = model.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens=max_new_tokens,\n",
    "            do_sample=False,\n",
    "            repetition_penalty=1.3,\n",
    "            pad_token_id=tokenizer.eos_token_id,\n",
    "            eos_token_id=tokenizer.eos_token_id\n",
    "        )\n",
    "\n",
    "    # Decode only new tokens\n",
    "    input_len = inputs['input_ids'].shape[1]\n",
    "    new_tokens = outputs[0][input_len:]\n",
    "    response = tokenizer.decode(new_tokens, skip_special_tokens=True)\n",
    "\n",
    "    # Remove garbage output\n",
    "    garbage = ['<unused', 'élaboration', 'console.log', 'jacques',\n",
    "               'ripetere', 'Jusqu', '};', '// Output']\n",
    "    for g in garbage:\n",
    "        if g in response:\n",
    "            response = response[:response.index(g)]\n",
    "\n",
    "    return response.strip()\n",
    "\n",
    "# Quick test\n",
    "print(ask('What is binary search?'))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 7 — Start Flask API + ngrok tunnel\n",
    "from flask import Flask, request, jsonify\n",
    "from flask_cors import CORS\n",
    "from pyngrok import ngrok\n",
    "import threading\n",
    "\n",
    "# ⚠️ Add your ngrok authtoken from dashboard.ngrok.com\n",
    "NGROK_TOKEN = 'your_ngrok_authtoken_here'\n",
    "ngrok.set_auth_token(NGROK_TOKEN)\n",
    "\n",
    "app = Flask(__name__)\n",
    "CORS(app)\n",
    "\n",
    "@app.route('/ask', methods=['POST'])\n",
    "def answer():\n",
    "    data = request.json\n",
    "    question = data.get('question', '')\n",
    "    if not question:\n",
    "        return jsonify({'error': 'No question provided'}), 400\n",
    "    response = ask(question)\n",
    "    return jsonify({'answer': response})\n",
    "\n",
    "@app.route('/health', methods=['GET'])\n",
    "def health():\n",
    "    return jsonify({'status': 'online'})\n",
    "\n",
    "# Start Flask in background\n",
    "def run_flask():\n",
    "    app.run(port=5000)\n",
    "\n",
    "thread = threading.Thread(target=run_flask)\n",
    "thread.daemon = True\n",
    "thread.start()\n",
    "\n",
    "# Get public URL\n",
    "public_url = ngrok.connect(5000)\n",
    "print(f'✅ API is live at: {public_url}')\n",
    "print(f'\\n⚠️  Update API_URL in frontend/index.html with this URL!')\n",
    "print(f'\\nHealth check: {public_url}/health')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 8 — (Optional) Launch Gradio interface\n",
    "import gradio as gr\n",
    "\n",
    "demo = gr.Interface(\n",
    "    fn=ask,\n",
    "    inputs=gr.Textbox(\n",
    "        label='Ask a CS Algorithm Question',\n",
    "        placeholder='e.g. What is binary search? Explain quicksort.',\n",
    "        lines=3\n",
    "    ),\n",
    "    outputs=gr.Textbox(\n",
    "        label='Answer',\n",
    "        lines=10\n",
    "    ),\n",
    "    title='🤖 CS Algorithm Q&A Assistant',\n",
    "    description='Ask any question about data structures and algorithms!',\n",
    "    examples=[\n",
    "        ['What is binary search and what is its time complexity?'],\n",
    "        ['Explain quicksort algorithm'],\n",
    "        ['What is a linked list?'],\n",
    "        ['What is the difference between BFS and DFS?'],\n",
    "        ['Explain dynamic programming with an example'],\n",
    "        ['What is a hash table?'],\n",
    "    ],\n",
    "    theme=gr.themes.Soft()\n",
    ")\n",
    "\n",
    "demo.launch(share=True)"
   ]
  }
 ]
